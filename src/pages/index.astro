<script>
  // ── CAMPER MARKISE ────────────────────────────
  const btn = document.getElementById('camper-menu-btn');
  const markise = document.getElementById('markise');

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    markise.classList.toggle('open');
  });
  document.addEventListener('click', (e) => {
    if (!btn.contains(e.target) && !markise.contains(e.target)) {
      markise.classList.remove('open');
    }
  });
  markise.querySelectorAll('.mlink').forEach(link => {
    link.addEventListener('click', () => markise.classList.remove('open'));
  });

  // ── SPRACHUMSCHALTER ──────────────────────────
  document.querySelectorAll('.lb').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.lb').forEach(x => x.classList.remove('on'));
      b.classList.add('on');
    });
  });

  // ── LIGHTBOX ──────────────────────────────────
  const allImages = [
    '/images/galerie-5.jpg',
    '/images/galerie-1.jpg',
    '/images/galerie-sanitaer.jpg',
    '/images/galerie-2.jpg',
    '/images/galerie-6.jpg',
    '/images/galerie-7.jpg',
    '/images/galerie-8.jpg',
    '/images/galerie-9.jpg',
    '/images/galerie-10.jpg',
    '/images/hero.jpg'
  ];
  let currentImg = 0;

  function openLightbox(index) {
    currentImg = index;
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    const counter = document.getElementById('lightbox-counter');
    lb.style.display = 'flex';
    img.src = allImages[currentImg];
    counter.textContent = (currentImg + 1) + ' / ' + allImages.length;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }

  function nextImg() {
    currentImg = (currentImg + 1) % allImages.length;
    document.getElementById('lightbox-img').src = allImages[currentImg];
    document.getElementById('lightbox-counter').textContent =
      (currentImg + 1) + ' / ' + allImages.length;
  }

  function prevImg() {
    currentImg = (currentImg - 1 + allImages.length) % allImages.length;
    document.getElementById('lightbox-img').src = allImages[currentImg];
    document.getElementById('lightbox-counter').textContent =
      (currentImg + 1) + ' / ' + allImages.length;
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.gal-img').forEach(function(img, i) {
      img.addEventListener('click', function() { openLightbox(i); });
    });

    document.querySelector('.gal-plus').addEventListener('click', function() {
      openLightbox(4);
    });

    document.getElementById('lb-close').addEventListener('click', closeLightbox);
    document.getElementById('lb-next').addEventListener('click', nextImg);
    document.getElementById('lb-prev').addEventListener('click', prevImg);

    document.getElementById('lightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      const lb = document.getElementById('lightbox');
      if (lb.style.display === 'flex') {
        if (e.key === 'ArrowRight') nextImg();
        if (e.key === 'ArrowLeft') prevImg();
        if (e.key === 'Escape') closeLightbox();
      }
    });
  });
</script>


