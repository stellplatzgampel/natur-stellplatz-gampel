  // ── SPRACHE SETZEN ──────────────────────────
  function setLang(lang) {
    document.documentElement.lang = lang;
    localStorage.setItem('lang', lang);
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (t[key] !== undefined) el.textContent = t[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (t[key] !== undefined) el.placeholder = t[key];
    });
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('on', btn.dataset.lang === lang);
    });
  }

  // ── CAMPER MARKISE ────────────────────────────
  const btn = document.getElementById('camper-menu-btn');
  const markise = document.getElementById('markise');

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    markise.classList.toggle('open');
  });
  document.addEventListener('click', (e) => {
    if (!btn.contains(e.target) && !markise.contains(e.target)) {
      markise.classList.remove('open');
    }
  });
  markise.querySelectorAll('.mlink').forEach(link => {
    link.addEventListener('click', () => markise.classList.remove('open'));
  });

  // ── LIGHTBOX ──────────────────────────────────
  const allImages = [
    '/images/galerie-5.jpg',
    '/images/galerie-1.jpg',
    '/images/galerie-sanitaer2.jpg',
    '/images/galerie-winter.jpg',
    '/images/galerie-2.jpg',
    '/images/galerie-3.jpg',
    '/images/galerie-4.jpg',
    '/images/galerie-6.jpg',
    '/images/galerie-7.jpg',
    '/images/galerie-8.jpg',
    '/images/galerie-9.jpg',
    '/images/galerie-10.jpg',
    '/images/galerie-sanitaer.jpg',
    '/images/hero.jpg'
  ];
  let currentImg = 0;

  function openLightbox(index) {
    currentImg = index;
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    const counter = document.getElementById('lightbox-counter');
    lb.style.display = 'flex';
    img.src = allImages[currentImg];
    counter.textContent = (currentImg + 1) + ' / ' + allImages.length;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }

  function nextImg() {
    currentImg = (currentImg + 1) % allImages.length;
    document.getElementById('lightbox-img').src = allImages[currentImg];
    document.getElementById('lightbox-counter').textContent =
      (currentImg + 1) + ' / ' + allImages.length;
  }

  function prevImg() {
    currentImg = (currentImg - 1 + allImages.length) % allImages.length;
    document.getElementById('lightbox-img').src = allImages[currentImg];
    document.getElementById('lightbox-counter').textContent =
      (currentImg + 1) + ' / ' + allImages.length;
  }

  document.addEventListener('DOMContentLoaded', function() {
    // Gespeicherte Sprache anwenden
    const saved = localStorage.getItem('lang') || 'de';
    setLang(saved);

    document.querySelectorAll('.gal-img').forEach(function(img, i) {
      img.addEventListener('click', function() { openLightbox(i); });
    });

    document.querySelector('.gal-plus').addEventListener('click', function() {
      openLightbox(4);
    });

    document.getElementById('lb-close').addEventListener('click', closeLightbox);
    document.getElementById('lb-next').addEventListener('click', nextImg);
    document.getElementById('lb-prev').addEventListener('click', prevImg);

    document.getElementById('lightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      const lb = document.getElementById('lightbox');
      if (lb.style.display === 'flex') {
        if (e.key === 'ArrowRight') nextImg();
        if (e.key === 'ArrowLeft') prevImg();
        if (e.key === 'Escape') closeLightbox();
      }
    });
  });
</script>


<button id="scrolltop"
  onclick="window.scrollTo({top:0,behavior:'smooth'})"
  style="position:fixed;bottom:28px;right:24px;z-index:999;
    width:52px;height:52px;border-radius:50%;
    background:#8B2020;color:#fff;border:none;cursor:pointer;
    font-size:24px;box-shadow:0 4px 16px rgba(0,0,0,0.3);
    display:none;align-items:center;justify-content:center">↑</button>
<script>
const st = document.getElementById('scrolltop');
window.addEventListener('scroll',()=>{
  st.style.display = window.scrollY > 400 ? 'flex' : 'none';
});
</script>

