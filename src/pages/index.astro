---
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Natur Stellplatz Gampel – Wohnmobil Stellplatz Wallis</title>
  <meta name="description" content="Naturnaher Wohnmobilstellplatz in Gampel, Wallis. Ohne Reservation, ab CHF 26 pro Nacht, ganzjährig geöffnet. Direkt an der Rhone." />
  <meta property="og:title" content="Natur Stellplatz Gampel – Wohnmobil Stellplatz Wallis" />
  <meta property="og:description" content="Ohne Reservation, freie Platzwahl, ganzjährig geöffnet. Ab CHF 26 pro Nacht." />
  <meta property="og:image" content="https://static.wixstatic.com/media/fddf3e_a6f2f6440d024ab8aa82dfba7ace26fe~mv2.jpg" />
  <link rel="preconnect" href="https://static.wixstatic.com" />
  <style>
    /* ── VARIABLEN ───────────────────────────── */
    :root {
      --rot:      #8B2020;
      --gruen:    #2D5016;
      --bg-hell:  #FAF8F4;
      --bg-alt:   #EDE9E0;
      --text:     #1A1A18;
      --text-soft:#6A6A64;
      --serif:    'Palatino Linotype', Palatino, Georgia, serif;
      --sans:     -apple-system, 'Helvetica Neue', sans-serif;
    }

    /* ── RESET ───────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--bg-hell); color: var(--text); font-family: var(--sans); line-height: 1.65; }
    h1, h2, h3, h4 { font-family: var(--serif); line-height: 1.22; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* ── NAV ─────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 300;
      height: 64px; padding: 0 2rem;
      background: rgba(250, 248, 244, 0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0,0,0,.08);
      display: flex; align-items: center; justify-content: space-between; gap: 1.5rem;
    }
    .nav-logo {
      font-family: var(--serif); font-size: .95rem; font-weight: bold;
      color: var(--rot); white-space: nowrap; flex-shrink: 0; line-height: 1.3;
    }
    .nav-logo span { display: block; font-size: .78rem; font-weight: 400; color: var(--text-soft); }
    .nav-links {
      display: flex; gap: 1.75rem; list-style: none;
      flex: 1; justify-content: center;
    }
    .nav-links a {
      font-size: .85rem; font-weight: 500; color: var(--text);
      transition: color .18s;
    }
    .nav-links a:hover { color: var(--rot); }
    .lang {
      display: flex; gap: .25rem; flex-shrink: 0;
    }
    .lang-btn {
      border: 1px solid #ccc; background: none;
      padding: .2rem .55rem; font-size: .72rem; font-weight: 600;
      letter-spacing: .04em; cursor: pointer; border-radius: 3px;
      color: var(--text); font-family: var(--sans); transition: all .18s;
    }
    .lang-btn.active,
    .lang-btn:hover { background: var(--rot); color: #fff; border-color: var(--rot); }

    /* ── HERO ────────────────────────────────── */
    .hero {
      position: relative; height: 100vh; min-height: 600px;
      overflow: hidden; padding-top: 64px;
    }
    .hero-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(160deg, rgba(0,0,0,.12) 0%, rgba(0,0,0,.58) 100%);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 2rem 1.5rem;
    }
    .hero-badge {
      display: inline-block;
      background: rgba(45, 80, 22, .9);
      color: #fff; font-size: .75rem; font-weight: 600;
      letter-spacing: .06em; padding: .4rem 1.2rem;
      border-radius: 2rem; margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: clamp(1.9rem, 5vw, 3.5rem);
      color: #fff;
      text-shadow: 0 2px 18px rgba(0,0,0,.45);
      margin-bottom: .75rem; max-width: 760px;
    }
    .hero-sub {
      color: rgba(255,255,255,.88);
      font-size: clamp(.95rem, 1.8vw, 1.15rem);
      text-shadow: 0 1px 8px rgba(0,0,0,.4);
      margin-bottom: 2.25rem; max-width: 560px;
    }
    .btn-primary {
      display: inline-block;
      background: var(--rot); color: #fff;
      padding: .9rem 2.6rem; border-radius: 4px;
      font-size: 1rem; font-weight: 700; font-family: var(--sans);
      border: none; cursor: pointer;
      transition: background .2s, transform .12s;
    }
    .btn-primary:hover { background: #a52626; transform: translateY(-2px); }

    /* ── SECTIONS SHARED ─────────────────────── */
    .sec { padding: 5rem 1.5rem; }
    .sec--alt { background: var(--bg-alt); }
    .wrap { max-width: 1140px; margin: 0 auto; }
    .sec-tag {
      display: block; text-align: center;
      font-size: .75rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: var(--rot); margin-bottom: .6rem;
    }
    .sec-title {
      font-family: var(--serif);
      font-size: clamp(1.55rem, 3vw, 2.2rem);
      color: var(--text); text-align: center; margin-bottom: .75rem;
    }
    .sec-lead {
      text-align: center; color: var(--text-soft);
      font-size: 1rem; max-width: 620px;
      margin: 0 auto 3rem; line-height: 1.72;
    }

    /* ── ICON BOX (kein Emoji) ───────────────── */
    .icon-box {
      width: 52px; height: 52px; border-radius: 10px;
      background: var(--bg-alt);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem; flex-shrink: 0;
    }
    .icon-box svg {
      width: 26px; height: 26px;
      stroke: var(--rot); fill: none;
      stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── SO EINFACH GEHT'S ───────────────────── */
    .steps-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }
    .step {
      background: #fff; border-radius: 10px;
      padding: 2rem 1.75rem; text-align: center;
      box-shadow: 0 2px 16px rgba(0,0,0,.06);
    }
    .step-num {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--rot); color: #fff;
      font-family: var(--serif); font-size: 1.3rem; font-weight: bold;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto .75rem;
    }
    .step .icon-box { margin: 0 auto .9rem; }
    .step h3 { font-size: 1.1rem; margin-bottom: .45rem; color: var(--text); }
    .step p { font-size: .875rem; color: var(--text-soft); line-height: 1.65; }

    /* ── STATS ───────────────────────────────── */
    .stats {
      background: var(--rot); padding: 2.75rem 1.5rem;
    }
    .stats-grid {
      max-width: 1140px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: .5rem; text-align: center;
    }
    .stat { padding: .75rem 1rem; }
    .stat-num {
      font-family: var(--serif); font-size: 2.6rem;
      font-weight: bold; color: #fff; line-height: 1;
    }
    .stat-label { color: rgba(255,255,255,.78); font-size: .85rem; margin-top: .35rem; }

    /* ── FEATURES ────────────────────────────── */
    .feat-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.35rem;
    }
    .feat {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      border-left: 4px solid var(--gruen);
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .feat h3 { font-size: 1.02rem; color: var(--gruen); margin-bottom: .4rem; }
    .feat p { font-size: .875rem; color: var(--text-soft); line-height: 1.65; }

    /* ── PREISE ──────────────────────────────── */
    .preise-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }
    .preis-col {
      background: #fff; border-radius: 10px; padding: 2.25rem;
      box-shadow: 0 2px 18px rgba(0,0,0,.07);
    }
    .preis-col-title {
      font-family: var(--serif); font-size: 1.2rem;
      color: var(--text); margin-bottom: 1.5rem;
      padding-bottom: .9rem; border-bottom: 2px solid var(--bg-alt);
    }
    .preis-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: .6rem 0; border-bottom: 1px solid var(--bg-alt);
      font-size: .9rem;
    }
    .preis-row:last-of-type { border-bottom: none; }
    .preis-row-label { color: var(--text-soft); }
    .preis-row-val { font-family: var(--serif); font-weight: bold; color: var(--rot); font-size: 1.05rem; }
    .preis-row-note { color: var(--text); font-size: .875rem; }
    .preis-unbegrenzt { text-align: center; margin: 1.25rem 0; font-size: .82rem; color: var(--text-soft); font-style: italic; }
    .btn-book {
      display: block; width: 100%;
      background: var(--rot); color: #fff;
      padding: .9rem; border-radius: 4px;
      font-size: .95rem; font-weight: 700; font-family: var(--sans);
      border: none; cursor: pointer; text-align: center;
      transition: background .2s; margin-top: 1.5rem;
    }
    .btn-book:hover { background: #a52626; }
    .incl-list { list-style: none; }
    .incl-list li {
      display: flex; align-items: flex-start; gap: .65rem;
      padding: .55rem 0; border-bottom: 1px solid var(--bg-alt);
      font-size: .875rem; color: var(--text);
    }
    .incl-list li:last-child { border-bottom: none; }
    .incl-check {
      width: 18px; height: 18px; border-radius: 50%;
      background: var(--gruen); flex-shrink: 0; margin-top: .1rem;
      display: flex; align-items: center; justify-content: center;
    }
    .incl-check svg {
      width: 10px; height: 10px;
      stroke: #fff; fill: none; stroke-width: 2.5;
      stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── GALERIE ─────────────────────────────── */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: 300px 260px;
      gap: 8px; border-radius: 10px; overflow: hidden; margin-top: 3rem;
    }
    .gallery-grid img { width: 100%; height: 100%; object-fit: cover; }
    .g1 { grid-column: 1 / span 7; grid-row: 1; }
    .g2 { grid-column: 8 / span 5; grid-row: 1; }
    .g3 { grid-column: 1 / span 4; grid-row: 2; }
    .g4 { grid-column: 5 / span 4; grid-row: 2; }
    .g5 { grid-column: 9 / span 4; grid-row: 2; }

    /* ── OPEN AIR ────────────────────────────── */
    .openair {
      background: #112008; padding: 4.5rem 1.5rem;
    }
    .openair-inner {
      max-width: 1140px; margin: 0 auto;
      display: flex; flex-wrap: wrap;
      align-items: center; justify-content: space-between; gap: 2.5rem;
    }
    .openair-date-tag {
      font-size: .78rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: rgba(255,255,255,.55);
      margin-bottom: .5rem;
    }
    .openair-title {
      font-family: var(--serif);
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      color: #fff; margin-bottom: .75rem;
    }
    .openair-details {
      color: rgba(255,255,255,.75); font-size: .9rem; line-height: 1.8;
    }
    .openair-cta { text-align: center; flex-shrink: 0; }
    .openair-price {
      font-family: var(--serif); font-size: 3rem;
      color: #fff; font-weight: bold; line-height: 1; margin-bottom: .35rem;
    }
    .openair-price-note { color: rgba(255,255,255,.6); font-size: .82rem; margin-bottom: 1.5rem; }
    .btn-openair {
      display: inline-block;
      background: #fff; color: #112008;
      padding: .85rem 2.2rem; border-radius: 4px;
      font-size: .95rem; font-weight: 700; font-family: var(--sans);
      transition: background .2s;
    }
    .btn-openair:hover { background: var(--bg-alt); }

    /* ── AKTIVITÄTEN ─────────────────────────── */
    .akt-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.75rem;
    }
    .akt-item {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .akt-item h3 { font-size: 1.05rem; color: var(--gruen); margin-bottom: .45rem; }
    .akt-item p { font-size: .875rem; color: var(--text-soft); line-height: 1.65; }
    .akt-footer { text-align: center; margin-top: 2.5rem; }
    .akt-footer p { font-size: .95rem; color: var(--text-soft); margin-bottom: .5rem; }
    .akt-gruss { font-family: var(--serif); font-size: 1.25rem; font-style: italic; color: var(--rot); }

    /* ── BEWERTUNGEN ─────────────────────────── */
    .reviews-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 1.5rem;
    }
    .review {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .review-top { display: flex; align-items: center; gap: .75rem; margin-bottom: 1rem; }
    .review-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--bg-alt); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--serif); font-size: 1rem; font-weight: bold; color: var(--rot);
    }
    .review-name { font-weight: 700; font-size: .875rem; }
    .review-meta { font-size: .75rem; color: var(--text-soft); margin-top: .1rem; }
    .review-stars { color: #F4B400; font-size: 1rem; margin-bottom: .65rem; }
    .review-text { font-size: .875rem; color: #444; line-height: 1.72; font-style: italic; }

    /* ── KONTAKT ─────────────────────────────── */
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
    .kontakt-block h3 { font-family: var(--serif); font-size: 1.15rem; color: var(--rot); margin-bottom: 1.5rem; }
    .k-item { display: flex; gap: .85rem; align-items: flex-start; margin-bottom: 1.1rem; }
    .k-item-icon {
      width: 36px; height: 36px; border-radius: 8px;
      background: var(--bg-alt); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .k-item-icon svg {
      width: 18px; height: 18px; stroke: var(--rot); fill: none;
      stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round;
    }
    .k-item-text { font-size: .9rem; line-height: 1.55; }
    .k-item-text a { transition: color .18s; }
    .k-item-text a:hover { color: var(--rot); }
    .k-item-label { font-size: .75rem; color: var(--text-soft); margin-top: .1rem; }
    .k-divider { border: none; border-top: 1px solid var(--bg-alt); margin: 1.5rem 0; }
    .k-hinweis {
      background: var(--bg-alt); border-radius: 8px; padding: 1rem 1.2rem;
      font-size: .85rem; color: var(--text-soft); line-height: 1.6;
    }
    .map-box {
      background: var(--bg-alt); border-radius: 10px; height: 360px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: .75rem; border: 2px dashed #ccc; color: var(--text-soft);
    }
    .map-box svg { width: 48px; height: 48px; stroke: #bbb; fill: none; stroke-width: 1.3; stroke-linecap: round; stroke-linejoin: round; }
    .map-box p { font-size: .875rem; }
    .map-link { color: var(--rot); font-size: .85rem; font-weight: 600; }
    .map-link:hover { text-decoration: underline; }

    /* ── FOOTER ──────────────────────────────── */
    footer {
      background: #111110; color: rgba(255,255,255,.7);
      padding: 3.5rem 1.5rem 2rem;
    }
    .footer-grid {
      max-width: 1140px; margin: 0 auto;
      display: flex; flex-wrap: wrap; gap: 2.5rem;
      justify-content: space-between; align-items: flex-start;
      padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .footer-logo { font-family: var(--serif); font-size: 1.1rem; color: #fff; margin-bottom: .3rem; }
    .footer-sub { font-size: .82rem; color: rgba(255,255,255,.4); }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: .4rem; }
    .footer-links a { font-size: .85rem; color: rgba(255,255,255,.6); transition: color .18s; }
    .footer-links a:hover { color: #fff; }
    .footer-social-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .07em; color: rgba(255,255,255,.35); margin-bottom: .65rem; }
    .social-links { display: flex; gap: .5rem; }
    .social-link {
      width: 38px; height: 38px; border-radius: 50%;
      background: rgba(255,255,255,.08); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: .72rem; font-weight: 700; transition: background .2s;
    }
    .social-link:hover { background: var(--rot); }
    .footer-copy {
      max-width: 1140px; margin: 2rem auto 0;
      text-align: center; font-size: .75rem; color: rgba(255,255,255,.3);
    }

    /* ── RESPONSIVE ──────────────────────────── */
    @media (max-width: 860px) {
      .nav-links { display: none; }
      .kontakt-grid { grid-template-columns: 1fr; }
      .openair-inner { flex-direction: column; text-align: center; }
      .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .g1, .g2, .g3, .g4, .g5 { grid-column: span 1 !important; grid-row: auto !important; height: 200px; }
    }
    @media (max-width: 480px) {
      .sec { padding: 3.5rem 1.1rem; }
      .stats { padding: 2rem 1.1rem; }
      .openair { padding: 3rem 1.1rem; }
    }
  </style>
</head>
<body>

<!-- ─── 1. NAVIGATION ──────────────────────────────────────────── -->
<header class="nav">
  <a href="#" class="nav-logo">
    Natur Stellplatz
    <span>Gampel · Wallis</span>
  </a>
  <ul class="nav-links">
    <li><a href="#how">So geht's</a></li>
    <li><a href="#preise">Preise</a></li>
    <li><a href="#galerie">Galerie</a></li>
    <li><a href="#openair">Open Air</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
  <div class="lang">
    <button class="lang-btn active" data-lang="de">DE</button>
    <button class="lang-btn" data-lang="fr">FR</button>
    <button class="lang-btn" data-lang="en">EN</button>
  </div>
</header>


<!-- ─── 2. HERO ────────────────────────────────────────────────── -->
<section class="hero" id="top">
  <img
    class="hero-img"
    src="https://static.wixstatic.com/media/fddf3e_a6f2f6440d024ab8aa82dfba7ace26fe~mv2.jpg"
    alt="Natur Stellplatz Gampel – Luftaufnahme"
    fetchpriority="high"
  />
  <div class="hero-overlay">
    <div class="hero-badge">Ohne Reservation &middot; Immer Platz verfügbar &middot; Ganzjährig geöffnet</div>
    <h1>Wohnmobil Stellplatz<br/>Natur Stellplatz Gampel</h1>
    <p class="hero-sub">11'000 m² Grünfläche direkt an der Rhone – im Herzen des Wallis</p>
    <a href="#features" class="btn-primary">Stellplatz entdecken</a>
  </div>
</section>


<!-- ─── 3. SO EINFACH GEHT'S ──────────────────────────────────── -->
<section class="sec sec--alt" id="how">
  <div class="wrap">
    <span class="sec-tag">So einfach geht's</span>
    <h2 class="sec-title">In 3 Schritten zum Stellplatz</h2>
    <p class="sec-lead">Kein Stress, keine Reservation – einfach ankommen und geniessen.</p>
    <div class="steps-grid">

      <div class="step">
        <div class="step-num">1</div>
        <div class="icon-box" style="margin:0 auto .9rem;">
          <!-- credit card / bezahlen -->
          <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="10" y2="15"/></svg>
        </div>
        <h3>Bezahlen</h3>
        <p>Vor Ort via QR-Code an der Infotafel oder per Online-Vorauszahlung.</p>
      </div>

      <div class="step">
        <div class="step-num">2</div>
        <div class="icon-box" style="margin:0 auto .9rem;">
          <!-- parking / wohnmobil -->
          <svg viewBox="0 0 24 24"><path d="M1 11V17a1 1 0 0 0 1 1h1m16 0h1a1 1 0 0 0 1-1v-5L17 5H5a2 2 0 0 0-2 2v4M6 18a2 2 0 1 0 4 0 2 2 0 0 0-4 0Zm8 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0Z"/><path d="M3 11h18M14 5v6"/></svg>
        </div>
        <h3>Parkieren</h3>
        <p>Freie Platzwahl, Schatten oder Sonne, mit oder ohne Strom.</p>
      </div>

      <div class="step">
        <div class="step-num">3</div>
        <div class="icon-box" style="margin:0 auto .9rem;">
