---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Natur Stellplatz Gampel – Wohnmobil Stellplatz Wallis</title>
  <meta name="description" content="Naturnaher Wohnmobilstellplatz in Gampel, Wallis. Ohne Reservation, ab CHF 26 pro Nacht, ganzjährig geöffnet. Direkt an der Rhone." />
  <meta property="og:title" content="Natur Stellplatz Gampel – Wohnmobil Stellplatz Wallis" />
  <meta property="og:description" content="Ohne Reservation, freie Platzwahl, ganzjährig geöffnet. Ab CHF 26 pro Nacht." />
  <meta property="og:image" content="/images/hero.jpg" />
  <meta name="color-scheme" content="only light">
  <style>
    /* ── LIGHT MODE ──────────────────────────── */
    :root { color-scheme: only light; }

    /* ── VARIABLEN ───────────────────────────── */
    :root {
      --rot:      #8B2020;
      --gruen:    #2D5016;
      --bg-hell:  #FAF8F4;
      --bg-alt:   #EDE9E0;
      --text:     #1A1A18;
      --text-soft:#6A6A64;
      --serif:    'Palatino Linotype', Palatino, Georgia, serif;
      --sans:     -apple-system, 'Helvetica Neue', sans-serif;
    }

    /* ── RESET ───────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background-color: #FAF8F4 !important; }
    html { scroll-behavior: smooth; }
    body { background: var(--bg-hell); color: var(--text); font-family: var(--sans); line-height: 1.65; font-size: 17px; }
    h1, h2, h3, h4 { font-family: var(--serif); line-height: 1.22; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    p, li { font-size: 16px; line-height: 1.75; }
    .feat h3, .step h3, .akt-item h3 { font-size: 17px; font-weight: 600; }
    .feat p, .step p, .akt-item p, .review-text { font-size: 16px; line-height: 1.75; }
    .k-item-text { font-size: 16px; }

    /* ── MARKISE DROPDOWN ────────────────────── */
    .mlink {
      font-size: 15px; color: #1A1A18; text-decoration: none;
      padding: 9px 0; border-bottom: 1px solid rgba(0,0,0,0.06);
      display: block; transition: color 0.2s;
    }
    .mlink:last-child { border-bottom: none; }
    .mlink:hover { color: #8B2020; }
    .lb {
      border: 1px solid #ccc; background: none;
      padding: .25rem .65rem; font-size: .75rem; font-weight: 600;
      letter-spacing: .04em; cursor: pointer; border-radius: 3px;
      color: #1A1A18; font-family: var(--sans); transition: all .18s;
    }
    .lb.on,
    .lb:hover { background: var(--rot); color: #fff; border-color: var(--rot); }
    #markise.open { max-height: 320px !important; opacity: 1 !important; }

    /* ── HERO ────────────────────────────────── */
    .hero {
      position: relative; height: 100vh; min-height: 600px;
      overflow: hidden;
    }
    .hero-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.25);
      display: flex; flex-direction: column;
      align-items: center; justify-content: flex-start;
      text-align: center; padding: 28vh 1.5rem 2rem;
    }
    .hero h1 {
      font-size: clamp(46px, 6.5vw, 78px);
      font-weight: 800;
      color: #8B2020;
      text-shadow: 0 0 30px rgba(255,255,255,0.9), 0 2px 4px rgba(255,255,255,0.8);
      margin-bottom: .85rem; max-width: 820px;
    }
    .hero-sub {
      color: #ffffff;
      font-size: clamp(20px, 3vw, 32px);
      font-weight: 500;
      text-shadow: 0 2px 12px rgba(0,0,0,0.9);
      font-style: italic;
      font-family: var(--serif);
      margin-bottom: 2.5rem; max-width: 620px;
    }
    .btn-primary {
      display: inline-block;
      background: var(--rot); color: #fff;
      padding: .9rem 2.6rem; border-radius: 4px;
      font-size: 1rem; font-weight: 700; font-family: var(--sans);
      border: none; cursor: pointer;
      transition: background .2s, transform .12s;
    }
    .btn-primary:hover { background: #a52626; transform: translateY(-2px); }

    /* ── SECTIONS SHARED ─────────────────────── */
    .sec { padding: 5rem 1.5rem; background: #FAF8F4; }
    .sec--alt { background: var(--bg-alt); }
    .wrap { max-width: 1140px; margin: 0 auto; }
    .sec-tag {
      display: block; text-align: center;
      font-size: .75rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: var(--rot); margin-bottom: .6rem;
    }
    .sec-title {
      font-family: var(--serif);
      font-size: clamp(22px, 4vw, 32px);
      color: var(--text); text-align: center; margin-bottom: .75rem;
    }
    .sec-lead {
      text-align: center; color: var(--text-soft);
      font-size: 1rem; max-width: 620px;
      margin: 0 auto 3rem; line-height: 1.72;
    }

    /* ── ICON BOX ────────────────────────────── */
    .icon-box {
      width: 56px; height: 56px; border-radius: 10px;
      background: var(--bg-alt);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem; flex-shrink: 0;
    }
    .icon-box svg {
      width: 32px; height: 32px;
      stroke: var(--rot); fill: none;
      stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── SO EINFACH GEHT'S ───────────────────── */
    .steps-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }
    .step {
      background: #fff; border-radius: 10px;
      padding: 2rem 1.75rem; text-align: center;
      box-shadow: 0 2px 16px rgba(0,0,0,.06);
    }
    .step-num {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--rot); color: #fff;
      font-family: var(--serif); font-size: 1.3rem; font-weight: bold;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto .75rem;
    }
    .step .icon-box { margin: 0 auto .9rem; }
    .step h3 { font-size: clamp(14px, 2.5vw, 16px); margin-bottom: .45rem; color: var(--text); }
    .step p { font-size: clamp(12px, 2vw, 14px); color: var(--text-soft); line-height: 1.6; }

    /* ── STATS ───────────────────────────────── */
    .stats { background: var(--rot); padding: 2.75rem 1.5rem; }
    .stats-grid {
      max-width: 1140px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: .5rem; text-align: center;
    }
    .stat { padding: .75rem 1rem; }
    .stat-num {
      font-family: var(--serif); font-size: 2.6rem;
      font-weight: bold; color: #fff; line-height: 1;
    }
    .stat-label { color: rgba(255,255,255,.78); font-size: .85rem; margin-top: .35rem; }

    /* ── FEATURES ────────────────────────────── */
    .feat-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.35rem;
    }
    .feat {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      border-left: 4px solid var(--gruen);
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .feat h3 { font-size: clamp(14px, 2.5vw, 16px); color: var(--gruen); margin-bottom: .4rem; }
    .feat p { font-size: clamp(12px, 2vw, 14px); color: var(--text-soft); line-height: 1.6; }

    /* ── PREISE ──────────────────────────────── */
    .preise-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
    }
    .preis-col {
      background: #fff; border-radius: 10px; padding: 2.25rem;
      box-shadow: 0 2px 18px rgba(0,0,0,.07);
    }
    .preis-col-title {
      font-family: var(--serif); font-size: 1.2rem;
      color: var(--text); margin-bottom: 1.5rem;
      padding-bottom: .9rem; border-bottom: 2px solid var(--bg-alt);
    }
    .preis-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: .6rem 0; border-bottom: 1px solid var(--bg-alt); font-size: .9rem;
    }
    .preis-row:last-of-type { border-bottom: none; }
    .preis-row-label { color: var(--text-soft); }
    .preis-row-val { font-family: var(--serif); font-weight: bold; color: var(--rot); font-size: 1.05rem; }
    .preis-unbegrenzt { text-align: center; margin: 1.25rem 0; font-size: .82rem; color: var(--text-soft); font-style: italic; }
    .btn-book {
      display: block; width: 100%;
      background: var(--rot); color: #fff;
      padding: .9rem; border-radius: 4px;
      font-size: .95rem; font-weight: 700; font-family: var(--sans);
      border: none; cursor: pointer; text-align: center;
      transition: background .2s; margin-top: 1.5rem;
    }
    .btn-book:hover { background: #a52626; }
    .incl-list { list-style: none; }
    .incl-list li {
      display: flex; align-items: flex-start; gap: .65rem;
      padding: .55rem 0; border-bottom: 1px solid var(--bg-alt);
      font-size: .875rem; color: var(--text);
    }
    .incl-list li:last-child { border-bottom: none; }
    .incl-check {
      width: 18px; height: 18px; border-radius: 50%;
      background: var(--gruen); flex-shrink: 0; margin-top: .1rem;
      display: flex; align-items: center; justify-content: center;
    }
    .incl-check svg {
      width: 10px; height: 10px;
      stroke: #fff; fill: none; stroke-width: 2.5;
      stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── GALERIE ─────────────────────────────── */
    .galerie-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 10px;
      margin-top: 3rem;
    }
    .gal-main img {
      width: 100%; height: 280px; object-fit: cover;
      border-radius: 10px; cursor: pointer;
      transition: transform 0.2s; display: block;
    }
    .gal-small img {
      width: 100%; height: 180px; object-fit: cover;
      border-radius: 10px; cursor: pointer;
      transition: transform 0.2s; display: block;
    }
    .gal-img:hover { transform: scale(1.02); }
    .gal-plus {
      background: var(--bg-alt); border-radius: 10px;
      height: 180px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; cursor: pointer;
      color: var(--rot); font-size: 48px; font-weight: 300;
      border: 2px dashed rgba(139,32,32,0.3);
      transition: background 0.2s;
      grid-column: 1 / -1;
    }
    .gal-plus:hover { background: #E0DAD0; }

    /* ── AKTIVITÄTEN ─────────────────────────── */
    .akt-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    }
    .akt-item {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .akt-item h3 { font-size: clamp(14px, 2.5vw, 16px); color: var(--gruen); margin-bottom: .45rem; }
    .akt-item p { font-size: clamp(12px, 2vw, 14px); color: var(--text-soft); line-height: 1.6; }
    .akt-footer { text-align: center; margin-top: 2.5rem; }
    .akt-footer p { font-size: .95rem; color: var(--text-soft); margin-bottom: .5rem; }
    .akt-gruss { font-family: var(--serif); font-size: 1.25rem; font-style: italic; color: var(--rot); }

    /* ── OPEN AIR ────────────────────────────── */
    .openair { background: #112008; padding: 4.5rem 1.5rem; }
    .openair-inner {
      max-width: 1140px; margin: 0 auto;
      display: flex; flex-wrap: wrap;
      align-items: center; justify-content: space-between; gap: 2.5rem;
    }
    .openair-date-tag {
      font-size: .78rem; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: rgba(255,255,255,.55); margin-bottom: .5rem;
    }
    .openair-title {
      font-family: var(--serif); font-size: clamp(1.5rem, 3vw, 2.2rem);
      color: #fff; margin-bottom: .75rem;
    }
    .openair-details { color: rgba(255,255,255,.75); font-size: .9rem; line-height: 1.8; }
    .openair-cta { text-align: center; flex-shrink: 0; }
    .openair-price {
      font-family: var(--serif); font-size: 3rem;
      color: #fff; font-weight: bold; line-height: 1; margin-bottom: .35rem;
    }
    .openair-price-note { color: rgba(255,255,255,.6); font-size: .82rem; margin-bottom: 1.5rem; }
    .btn-openair {
      display: inline-block; background: #fff; color: #112008;
      padding: .85rem 2.2rem; border-radius: 4px;
      font-size: .95rem; font-weight: 700; font-family: var(--sans);
      transition: background .2s;
    }
    .btn-openair:hover { background: var(--bg-alt); }

    /* ── BEWERTUNGEN ─────────────────────────── */
    .reviews-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 1.5rem;
    }
    .review {
      background: #fff; border-radius: 10px; padding: 1.75rem;
      box-shadow: 0 1px 10px rgba(0,0,0,.05);
    }
    .review-top { display: flex; align-items: center; gap: .75rem; margin-bottom: 1rem; }
    .review-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--bg-alt); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--serif); font-size: 1rem; font-weight: bold; color: var(--rot);
    }
    .review-name { font-weight: 700; font-size: .875rem; }
    .review-meta { font-size: .75rem; color: var(--text-soft); margin-top: .1rem; }
    .review-stars { color: #F4B400; font-size: 1rem; margin-bottom: .65rem; }
    .review-text { font-size: .875rem; color: #444; line-height: 1.72; font-style: italic; }

    /* ── KONTAKT ─────────────────────────────── */
    .kontakt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
    .kontakt-block h3 { font-family: var(--serif); font-size: 1.15rem; color: var(--rot); margin-bottom: 1.5rem; }
    .k-item { display: flex; gap: .85rem; align-items: flex-start; margin-bottom: 1.1rem; }
    .k-item-icon {
      width: 36px; height: 36px; border-radius: 8px;
      background: var(--bg-alt); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .k-item-icon svg {
      width: 18px; height: 18px; stroke: var(--rot); fill: none;
      stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round;
    }
    .k-item-text { font-size: .9rem; line-height: 1.55; }
    .k-item-text a { transition: color .18s; }
    .k-item-text a:hover { color: var(--rot); }
    .k-item-label { font-size: .75rem; color: var(--text-soft); margin-top: .1rem; }
    .k-divider { border: none; border-top: 1px solid var(--bg-alt); margin: 1.5rem 0; }
    .k-hinweis {
      background: var(--bg-alt); border-radius: 8px; padding: 1rem 1.2rem;
      font-size: .85rem; color: var(--text-soft); line-height: 1.6;
    }
    .map-box {
      background: var(--bg-alt); border-radius: 10px; height: 360px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: .75rem; border: 2px dashed #ccc; color: var(--text-soft);
    }
    .map-box svg { width: 48px; height: 48px; stroke: #bbb; fill: none; stroke-width: 1.3; stroke-linecap: round; }
    .map-box p { font-size: .875rem; }
    .map-link { color: var(--rot); font-size: .85rem; font-weight: 600; }
    .map-link:hover { text-decoration: underline; }

    /* ── FOOTER ──────────────────────────────── */
    footer { background: #111110; color: rgba(255,255,255,.7); padding: 3.5rem 1.5rem 2rem; }
    .footer-grid {
      max-width: 1140px; margin: 0 auto;
      display: flex; flex-wrap: wrap; gap: 2.5rem;
      justify-content: space-between; align-items: flex-start;
      padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .footer-logo { font-family: var(--serif); font-size: 1.1rem; color: #fff; margin-bottom: .3rem; }
    .footer-sub { font-size: .82rem; color: rgba(255,255,255,.4); }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: .4rem; }
    .footer-links a { font-size: .85rem; color: rgba(255,255,255,.6); transition: color .18s; }
    .footer-links a:hover { color: #fff; }
    .footer-social-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .07em; color: rgba(255,255,255,.35); margin-bottom: .65rem; }
    .social-links { display: flex; gap: .5rem; }
    .social-link {
      width: 38px; height: 38px; border-radius: 50%;
      background: rgba(255,255,255,.08); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: .72rem; font-weight: 700; transition: background .2s;
    }
    .social-link:hover { background: var(--rot); }
    .footer-copy {
      max-width: 1140px; margin: 2rem auto 0;
      text-align: center; font-size: .75rem; color: rgba(255,255,255,.3);
    }

    /* ── RESPONSIVE ──────────────────────────── */
    @media (max-width: 860px) {
      .kontakt-grid { grid-template-columns: 1fr; }
      .openair-inner { flex-direction: column; text-align: center; }
      .akt-grid { grid-template-columns: 1fr 1fr; }
      .hero-overlay { padding-top: 22vh; }
    }
    @media (max-width: 768px) {
      .hero-logo { top:16px !important; left:16px !important; }
      .hero-logo img { height:52px !important; }
      .hero-camper { top:16px !important; right:16px !important; }
    }
    @media (max-width: 560px) {
      .akt-grid { grid-template-columns: 1fr; }
      .sec { padding: 3.5rem 1.1rem; }
      .stats { padding: 2rem 1.1rem; }
      .openair { padding: 3rem 1.1rem; }
      .galerie-grid { grid-template-columns: 1fr; }
      .gal-plus { grid-column: 1; }
      .hero-overlay { padding-top: 18vh; }
    }
  </style>
</head>
<body>


<!-- ─── 1. HERO ────────────────────────────────────────────────── -->
<section class="hero" id="top">
  <img class="hero-img" src="/images/hero.jpg"
       alt="Natur Stellplatz Gampel – Drohnenaufnahme" fetchpriority="high" />

  <div class="hero-overlay">

    <!-- ── NAV oben im Hero (transparent, absolute) ── -->
    <div style="position:absolute;inset:0;z-index:10;pointer-events:none">

      <!-- Logo links -->
      <a href="#" style="
        position:absolute;
        top:20px;
        left:24px;
        z-index:100;
        display:block;
        background:#ffffff;
        border-radius:16px;
        padding:8px;
        box-shadow:0 4px 16px rgba(0,0,0,0.4);
        line-height:0;
        text-decoration:none;
        pointer-events:all;
      ">
        <img
          src="/images/logo.png"
          alt="Logo"
          style="height:68px;width:68px;display:block;object-fit:contain;">
      </a>

      <!-- Camper-Button rechts -->
      <div class="hero-camper"
           style="position:absolute;top:20px;right:24px;z-index:100;
                  pointer-events:all">
        <button id="camper-menu-btn" style="background:#8B2020;border:none;
          border-radius:8px;cursor:pointer;padding:10px 14px;
          display:flex;flex-direction:column;align-items:center;gap:4px">
          <!-- Camper SVG weiss -->
          <svg width="38" height="26" viewBox="0 0 38 26" fill="none"
            stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="6" width="24" height="14" rx="2.5"/>
            <path d="M25 10 Q25 6 29 6 L33 7 Q37 8 37 12 L37 20 L25 20 Z"/>
            <rect x="4" y="9" width="6" height="5" rx="1"/>
            <rect x="12" y="9" width="6" height="5" rx="1"/>
            <path d="M26 10 L26 17 L35 17 L35 13 L31 9 Z"/>
            <circle cx="9" cy="21" r="4"/>
            <circle cx="9" cy="21" r="2"/>
            <circle cx="29" cy="21" r="4"/>
            <circle cx="29" cy="21" r="2"/>
            <line x1="4" y1="6" x2="22" y2="6"/>
            <line x1="5" y1="6" x2="3" y2="3"/>
            <line x1="21" y1="6" x2="23" y2="3"/>
            <line x1="3" y1="3" x2="23" y2="3"/>
          </svg>
          <div style="width:36px;height:3px;background:rgba(255,255,255,0.75);
            border-radius:2px"></div>
        </button>

        <!-- Markise Dropdown (öffnet nach unten) -->
        <div id="markise" style="position:absolute;right:0;top:calc(100% + 4px);
          min-width:210px;background:#FAF8F4;
          border:1px solid rgba(139,32,32,0.2);
          border-radius:0 0 12px 12px;
          box-shadow:0 8px 24px rgba(0,0,0,0.18);
          max-height:0;overflow:hidden;opacity:0;
          transition:max-height 0.4s ease, opacity 0.3s ease;
          z-index:999">
          <div style="padding:16px 24px">
            <div style="height:6px;background:repeating-linear-gradient(
              90deg,#8B2020 0px,#8B2020 12px,#FAF8F4 12px,#FAF8F4 20px);
              margin:-16px -24px 12px -24px"></div>
            <nav style="display:flex;flex-direction:column">
              <a href="#how" class="mlink">So geht's</a>
              <a href="#preise" class="mlink">Preise</a>
              <a href="#galerie" class="mlink">Galerie</a>
              <a href="#openair" class="mlink">Open Air</a>
              <a href="#kontakt" class="mlink">Kontakt</a>
            </nav>
            <div style="display:flex;gap:6px;margin-top:14px;
              padding-top:12px;border-top:1px solid rgba(0,0,0,0.08)">
              <button class="lb on">DE</button>
              <button class="lb">FR</button>
              <button class="lb">EN</button>
            </div>
          </div>
        </div>
