    .info-row { display: flex; gap: .5rem; font-size: .92rem; padding: .4rem 0; color: #333; }
    .info-label { color: var(--soft); min-width: 120px; flex-shrink: 0; }
    hr { border: none; border-top: 1px solid #e8e4dc; margin: 2rem 0; }

    /* FOOTER */
